  <String Id="UpgradeDetectedDlgTitle" Value="Upgrade FSC Storage Service" />
  <String Id="UpgradeDetectedDlgDescription" Value="An installed version was detected. The installer will perform an upgrade." />
  <String Id="UpgradeDetectedDlgBody" Value="Data storage, HTTP/HTTPS, and service account settings will not be requested again. The existing appsettings.json will be preserved." />
