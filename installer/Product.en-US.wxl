  <String Id="ServiceDescription" Value="Simple File Storage Service" />
  <String Id="WelcomeDlgDescription" Value="This wizard will install FSC Storage Service: file storage with an HTTP API, background maintenance tasks, and an administrative CLI utility. Click Next to continue the installation." />
