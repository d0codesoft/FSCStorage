@inherits LayoutComponentBase

<RadzenLayout class="app-shell">
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem" class="app-header">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" ToggleAriaLabel="Toggle navigation" />
                <div class="brand-mark">FS</div>
                <div>
                    <div class="brand-title">FSC Storage</div>
                    <div class="brand-subtitle">Admin console</div>
                </div>
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" class="header-actions">
                <RadzenAppearanceToggle LightTheme="software" DarkTheme="software-dark" ButtonStyle="ButtonStyle.Light" ToggleButtonStyle="ButtonStyle.Dark" Variant="Variant.Flat" />
                <LoginDisplay />
            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>

    <RadzenSidebar @bind-Expanded="@sidebarExpanded" Responsive="true" class="app-sidebar">
        <NavMenu />
    </RadzenSidebar>

    <RadzenBody class="app-body">
        <main class="content-shell">
            @Body
        </main>
    </RadzenBody>
</RadzenLayout>

@code {
    private bool sidebarExpanded = true;
}
