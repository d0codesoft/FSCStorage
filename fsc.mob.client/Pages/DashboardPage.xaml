<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:fsc.mob.client.ViewModels"
             xmlns:api="clr-namespace:fsc.mob.client.Api"
             x:Class="fsc.mob.client.Pages.DashboardPage"
             x:DataType="viewModels:DashboardViewModel"
             Title="Dashboard">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Storage overview" FontSize="22" FontAttributes="Bold" />
            <Label Text="{Binding ServerUrl}" FontSize="12" />

            <Button Text="Refresh" Command="{Binding RefreshCommand}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding StatusMessage}" TextColor="Green" />
            <Label Text="{Binding ErrorMessage}" TextColor="Crimson" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Stored files" FontAttributes="Bold" />
                        <Label Text="{Binding StoredFileCount}" FontSize="22" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Storage used" FontAttributes="Bold" />
                        <Label Text="{Binding UsedBytes}" FontSize="22" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Tenant files" FontAttributes="Bold" />
                        <Label Text="{Binding TenantFileCount}" FontSize="22" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Active tenants" FontAttributes="Bold" />
                        <Label Text="{Binding TenantCount}" FontSize="22" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Label Text="Largest files" FontSize="18" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding LargestFiles}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="api:LargestFileViewModel">
                        <Border Padding="12" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding FileName}" FontAttributes="Bold" />
                                <Label Text="{Binding TenantName}" />
                                <Label Text="{Binding FileSizeDisplay}" />
                                <Label Text="{Binding CreatedUtcDisplay}" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Tenant usage" FontSize="18" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding TenantStatistics}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="api:TenantStorageStatisticsViewModel">
                        <Border Padding="12" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding TenantName}" FontAttributes="Bold" />
                                <Label Text="{Binding UsedBytesDisplay}" />
                                <Label Text="{Binding FileCount, StringFormat='Files: {0}'}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
