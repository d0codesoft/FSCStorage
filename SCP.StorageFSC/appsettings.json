{
  "Logging": {
    "FilePath": "app-.log",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Paths": {
    "BasePath": "",
    "LogsPath": "",
    "DataPath": ""
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5770"
      }
    }
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ],
    "RequireHeaderSymmetry": false
  }
}
