{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "SCP.StorageFSC": "Trace",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Paths": {
    "BasePath": "",
    "LogsPath": "",
    "DataPath": ""
  },
  "FileStorageCleanup": {
    "Enabled": true,
    "CompletedTaskRetentionDays": 30,
    "MultipartUploadSessionRetentionDays": 30,
    "InitialDelay": "00:05:00",
    "Interval": "1.00:00:00"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5770"
      }
    }
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ],
    "RequireHeaderSymmetry": false
  }
}
