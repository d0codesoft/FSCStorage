{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "SCP.StorageFSC": "Trace",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Paths": {
    "BasePath": "{ApplicationData}\\filestorage",
    "LogsPath": "{Root}\\logs",
    "DataPath": "{Root}\\data",
    "TempPath": "{Root}\\temp"
  },
  "MultipartSetting": {
    "MinPartSizeBytes": 5242880,
    "MaxPartSizeBytes": 104857600
  },
  "FileStorageCleanup": {
    "Enabled": true,
    "CompletedTaskRetentionDays": 30,
    "MultipartUploadSessionRetentionDays": 30,
    "InitialDelay": "00:05:00",
    "Interval": "1.00:00:00"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5770"
      }
    }
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ],
    "RequireHeaderSymmetry": false
  },
  "Authentication": {
    "OneTimeCode": {
      "EmailSenderName": "FSC.Storage",
      "EmailSenderAddress": "no-reply@scode.cloud",
      "EmailSubject": "Your FSC.Storage verification code",
      "CodeLifetimeMinutes": 5,
      "SmsEnabled": false
    },
    "Smtp": {
      "Host": "mail.scode.cloud",
      "Port": 587,
      "EnableSsl": true,
      "UserName": "no-reply@scode.cloud",
      "Password": "CHANGE_ME",
      "FromAddress": "no-reply@scode.cloud",
      "FromName": "FSC.Storage"
    },
    "Totp": {
      "Issuer": "FSC.Storage",
      "StepSeconds": 30,
      "CodeDigits": 6,
      "VerificationWindowSteps": 1,
      "SecretSizeBytes": 20
    }
  }
}
